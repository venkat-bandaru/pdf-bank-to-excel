# Runtime directories — keep the dirs (so Docker bind mounts have a target on
# fresh clones) but never commit their contents.
input/*
output/*
failed/*
logs/*
!input/.gitkeep
!output/.gitkeep
!failed/.gitkeep
!logs/.gitkeep

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Tools
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/

# OS
.DS_Store
Thumbs.db
